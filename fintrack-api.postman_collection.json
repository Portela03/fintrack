            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/ai/sessions/{{sessionId}}/messages", "host": ["{{baseUrl}}"], "path": ["ai", "sessions", "{{sessionId}}", "messages"] }
          },
          "response": []
