        {
          "name": "Listar simulações",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/financing/simulations", "host": ["{{baseUrl}}"], "path": ["financing", "simulations"] }
          },
          "response": []
