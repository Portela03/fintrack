            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/ai/sessions/{{sessionId}}/messages", "host": ["{{baseUrl}}"], "path": ["ai", "sessions", "{{sessionId}}", "messages"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Qual é a melhor forma de montar uma reserva de emergência?\"\n}"
