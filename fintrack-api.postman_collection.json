        {
          "name": "Criar simulação PRICE",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/financing/simulations", "host": ["{{baseUrl}}"], "path": ["financing", "simulations"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Apartamento Centro - PRICE\",\n  \"propertyValue\": 500000.00,\n  \"downPayment\": 100000.00,\n  \"loanMonths\": 360,\n  \"monthlyRate\": 0.8,\n  \"amortizationType\": \"PRICE\"\n}"
            }
          },
          "response": []
