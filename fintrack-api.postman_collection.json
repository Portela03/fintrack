      ]
    },
    {
      "name": "7. AI Assistant (Gemini)",
      "item": [
        {
          "name": "Criar sessão de chat",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('sessionId', json.id);",
                  "  console.log('✅ sessionId salvo:', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/ai/sessions", "host": ["{{baseUrl}}"], "path": ["ai", "sessions"] }
          },
          "response": []
        },
        {
          "name": "Listar sessões",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/ai/sessions", "host": ["{{baseUrl}}"], "path": ["ai", "sessions"] }
          },
